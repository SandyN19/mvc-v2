{% extends "base.html.twig" %}

{% block title %}Pig Game{% endblock %}

{% block body %}
<h1>Deck of cards</h1>
<p>Here is a shuffled deck of cards</p>
<div class="card-container">
    {% for card in hand %}
        <div class="card">{{ card.getAsString() }}</div>
    {% endfor %}
</div>
{% endblock %}